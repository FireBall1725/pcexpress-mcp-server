# PC Express MCP Server Configuration
# Copy this file to .env and fill in your values.

# App OAuth client secret (fixed value; printed by login_pcid.py). Required.
PCEXPRESS_CLIENT_SECRET=your_client_secret_here

# Refresh token from a one-time browser login. Get it by running:
#   PCEXPRESS_CLIENT_SECRET=... python login_pcid.py
# The server rotates and persists this automatically after first use.
PCEXPRESS_REFRESH_TOKEN=your_refresh_token_here

# Writable directory for the rotated refresh token + cached access token,
# cart-id TTL cache, and optional search cache. Must persist across restarts
# (a lost state file means re-running login_pcid.py).
PCEXPRESS_STATE_DIR=~/.pcexpress-mcp

# Optional fixed cart ID. When unset, the server safely resolves an OPEN cart
# for PCEXPRESS_BANNER + PCEXPRESS_STORE_ID via GET /customers/{id}/carts.
# PCEXPRESS_CART_ID=your_cart_id_here

# Cart-id in-process / disk TTL seconds (default 900 = 15 min).
# PCEXPRESS_CART_TTL_SEC=900

# Product search file cache under $PCEXPRESS_STATE_DIR/search-cache.
# Set PCEXPRESS_SEARCH_CACHE=0 to disable. Default TTL is 3 days.
# PCEXPRESS_SEARCH_CACHE=1
# PCEXPRESS_SEARCH_CACHE_TTL_SEC=259200

# Store ID (4-digit code for your preferred store)
PCEXPRESS_STORE_ID=your_store_id_here

# Banner: zehrs, loblaws, nofrills, superstore, independent, tandt
PCEXPRESS_BANNER=zehrs
